BOT_TOKEN=
WEBAPP_URL=https://yourdomain.com
API_PORT=8000
API_HOST=127.0.0.1
# Telegram user ID for browser testing (skips Telegram initData auth)
DEV_USER_ID=
# Fernet key for encrypting ClickUp tokens at rest. Generate with: python crypto.py genkey
# WARNING: losing this key makes stored tokens unrecoverable (users must re-run /clickup_setup).
ENCRYPTION_KEY=
# Background scheduler (autosync + notifications). 0 disables it entirely.
SCHEDULER_ENABLED=1
SCHEDULER_TICK_SECONDS=300
AUTOSYNC_INTERVAL_MINUTES=30
TIMER_CHECK_INTERVAL_MINUTES=15
# IANA timezone for digest times (e.g. Europe/Moscow); empty = server local time
APP_TZ=
